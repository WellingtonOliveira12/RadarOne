# ------------------------------------------------------------------------------
# .env.ml.example — RadarOne worker (Mercado Livre shard, Hostinger VPS)
#
# Copy to .env.ml on the VPS and fill in the real values.
# Keep .env.ml OUT of git. Keep permissions 600.
#
# The two envs that define this instance as an ML-only shard are already
# hard-set at the compose level (WORKER_SITES_INCLUDE + WATCHDOG_ENABLED=false);
# you do NOT need to set them here, but if you do, compose will override them.
# ------------------------------------------------------------------------------

# --- Database (Neon — production) --------------------------------------------
# SAME value used by the Render worker. Both workers must see the same DB.
DATABASE_URL=postgresql://USER:PASS@HOST/radarone_prod?sslmode=require

# --- Secrets (same as Render worker) -----------------------------------------
# Session crypto — MUST match the backend/worker value in Render, otherwise
# stored ML session storageState cannot be decrypted.
SESSION_ENCRYPTION_KEY=

# Optional Sentry DSN (safe to leave empty on the ML shard).
SENTRY_DSN=

# --- Telegram --------------------------------------------------------------
# Same bot token the Render worker uses, so user ad notifications keep going
# out via the same Telegram bot identity. Optional if you prefer the ML shard
# to be silent on user notifications, but then users won't get ML alerts.
TELEGRAM_BOT_TOKEN=

# DO NOT set ADMIN_TELEGRAM_CHAT_ID here. Watchdog is disabled on this shard
# (see docker-compose.ml.yml), so admin system alerts stay with Render only.

# --- Playwright ----------------------------------------------------------------
# Already baked into the image at /ms-playwright. Leave as-is unless you have
# a reason to override.
# PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# --- Worker tuning (optional) ------------------------------------------------
# Concurrency ceiling for the ML shard. The Hostinger VPS has a single vCPU
# and co-hosts n8n, so we keep this at 1 to avoid starving the other
# container. Even at 1 the ResilientScheduler will still handle all
# currently-active ML monitors (they run sequentially with jitter).
SCHEDULER_CONCURRENCY=1

# --- DO NOT touch below — enforced by docker-compose.ml.yml ------------------
# WORKER_SITES_INCLUDE=MERCADO_LIVRE
# WATCHDOG_ENABLED=false
